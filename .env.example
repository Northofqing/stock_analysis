# =====================================================================
# A股自选股智能分析系统 - 环境变量配置
# 复制为 .env 并按需修改；以 # 开头为注释
# =====================================================================

# ============ 1. 自选股 ============
# 6 位股票代码，逗号分隔
STOCK_LIST=601179,000876,002182,002413,002131,002195,002202,000987

# ============ 2. 数据库 ============
# SQLite 数据库路径（默认 data/stocks.db）
# DATABASE_PATH=data/stocks.db

# ============ 3. 运行模式（与命令行参数互斥） ============
# 定时任务：每日 SCHEDULE_TIME 触发
# SCHEDULE_ENABLED=false
# SCHEDULE_TIME=09:30

# 龙虎榜选股模式
# LHB_MODE=false
# LHB_DATE=20260128             # 留空=今日
# LHB_MIN_SCORE=60              # 0-100，建议 60/70/80

# 大盘复盘模式
# MARKET_REVIEW_ENABLED=false

# ============ 4. AI 模型（至少配 1 个 API_KEY） ============
# --- Gemini（Google）---
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_DELAY=2.0          # 秒
# GEMINI_REQUEST_DELAY=0.0        # 秒，调用间隔

# --- 豆包（字节）---
# DOUBAO_API_KEY=your_doubao_api_key_here
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL=ep-20241230184254-j6pvd

# --- OpenAI 兼容 ---
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 深度思考开关（Gemini thinkingConfig / 豆包 thinking / OpenAI reasoning_effort）
# AI_DEEP_THINKING=false

# 宏观 AI 新闻分析开关（默认开启=true）
# 关闭=不调用宏观新闻 AI 推荐选股，节省 LLM 调用与启动耗时
# MACRO_AI_ENABLED=true

# 持仓自动追踪开关（默认开启=true）
# 关闭=不自动把数据库 open 仓位加入候选池，且跳过模拟买卖与四大铁律
# POSITION_TRACKING_ENABLED=true

# 龙虎榜 Top10 自动追加开关（默认开启=true）
# 关闭=只用 STOCK_LIST，不把当日龙虎榜净买入 Top10 加入候选
# LHB_APPEND_ENABLED=true

# 当日涨停自动追加开关（默认开启=true）
# 关闭=不把当日涨停股加入候选池
# LIMIT_UP_APPEND_ENABLED=true

# ============ 5. 多 Agent 流水线（受 TradingAgents 启发） ============
# 默认开启：6 位分析师（基本面/技术面/资金面/消息面/行业板块/时间窗口）
#   → 多空 N 轮辩论 → 风控审查 → 仲裁终稿
# 完整一只股票约 9~11 次 LLM 调用；关闭后回退单 prompt
# AI_AGENT_PIPELINE=true

# 多空辩论轮数（1=只陈述, 2=互相反驳[默认], 3=深度对抗）
# AI_DEBATE_ROUNDS=2

# Agent 追踪日志：true 时打印每个 Agent 的输入切片/JSON 视角/多空全文/终稿
# 默认仅打印评分概要 + 终稿前 600 字预览
# AI_AGENT_TRACE=false

# Quick / Deep 双模型路由（不设则统一用主模型）
# Quick = 6 个分析师 + 风控（低延迟）
# Deep  = 多空辩论 + 仲裁（启用 AI_DEEP_THINKING 时打开思考）
# AI_QUICK_MODEL=gemini-2.5-flash-lite
# AI_DEEP_MODEL=gemini-2.5-flash
# DOUBAO_QUICK_MODEL=
# DOUBAO_DEEP_MODEL=
# OPENAI_QUICK_MODEL=gpt-4o-mini
# OPENAI_DEEP_MODEL=o3-mini

# ============ 6. 数据源 ============
# Tushare Pro Token（可选，用于补充财务/资金流）
# TUSHARE_TOKEN=your_tushare_token_here

# ============ 7. 搜索服务（新闻/消息面） ============
# 多 Key 轮转：用英文逗号分隔可配多把，自动按可用性切换
# SerpAPI（Google 搜索）
# SERPAPI_KEYS=key1,key2

# Tavily（备用搜索）
# TAVILY_API_KEYS=key1,key2

# 博查（Bocha）
# BOCHA_API_KEYS=key1,key2

# 东方财富新闻爬取（true 时启用本地爬取，无需 API key）
# ENABLE_EASTMONEY_NEWS=true

# ============ 8. 通知推送（按需启用） ============
# 任一渠道只需配齐对应字段即自动启用，无需开关
# 渠道未启用时留空即可

# --- 邮件（5 项必须同时配齐：缺一即报错）---
# EMAIL_SENDER=your_email@163.com           # 发件人邮箱（=SMTP 用户名）
# EMAIL_PASSWORD=your_smtp_authcode         # SMTP 授权码（非登录密码！）
# EMAIL_RECEIVERS=a@x.com,b@y.com           # 收件人，逗号分隔；第一个=主，其余=抄送
# SMTP_SERVER=smtp.163.com                  # 例：163=smtp.163.com / QQ=smtp.qq.com / Gmail=smtp.gmail.com
# SMTP_PORT=465                             # 465=SSL；587=STARTTLS

# --- 企业微信群机器人 ---
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# WECHAT_MAX_BYTES=4000                     # 单条消息上限，默认 4000

# --- 飞书群机器人 ---
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# FEISHU_MAX_BYTES=20000                    # 单条消息上限，默认 20000

# --- Telegram ---
# TELEGRAM_BOT_TOKEN=xxxxx:yyyyy
# TELEGRAM_CHAT_ID=123456789

# --- Pushover ---
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=

# --- 自定义 Webhook（可多个）---
# CUSTOM_WEBHOOK_URLS=https://hook1,https://hook2
# CUSTOM_WEBHOOK_BEARER_TOKEN=optional_bearer_token

# ============ 9. 其他 ============
# 并发分析线程数（默认 3）
# MAX_WORKERS=3

# 日志级别（debug/info/warn/error），默认 info
# RUST_LOG=info
