# ===================================
# A股自选股智能分析系统 - 环境变量配置
# ===================================
# 复制此文件为 .env 并根据实际情况修改

# ============ 股票列表配置 ============
# 自选股代码列表（逗号分隔，6位代码）
STOCK_LIST=601179,000876,002182,002413,002131,002195,002202,000987

# ============ AI分析配置 ============
# Gemini API密钥（必需）
GEMINI_API_KEY=your_gemini_api_key_here

# 豆包 API密钥（可选，字节跳动AI模型）
# DOUBAO_API_KEY=your_doubao_api_key_here
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL=ep-20241230184254-j6pvd

# OpenAI API密钥（可选，作为备用）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# ============ 数据源配置 ============
# Tushare Pro API Token（可选）
# TUSHARE_TOKEN=your_tushare_token_here

# ============ 通知推送配置 ============
# 邮件通知配置
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=smtp.163.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=your_email@163.com
EMAIL_SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=your_email@163.com
EMAIL_TO=recipient@gmail.com

# 企业微信通知（可选）
# WECOM_ENABLED=true
# WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key

# 钉钉通知（可选）
# DINGTALK_ENABLED=true
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token

# ============ 定时任务配置 ============
# 启用定时任务（true/false）
SCHEDULE_ENABLED=false

# 定时执行时间点（HH:MM格式，可用逗号分隔多个时间）
# 例如：09:30 表示每天9:30执行
# 例如：09:30,15:00 表示每天9:30和15:00各执行一次
SCHEDULE_TIME=09:30

# 仅在指定星期执行（1-7，1=周一，7=周日，逗号分隔）
# 例如：1,2,3,4,5 表示仅工作日执行
# SCHEDULE_WEEKDAYS=1,2,3,4,5

# ============ 大盘复盘配置 ============
# 启用大盘复盘（true/false）
MARKET_REVIEW_ENABLED=false

# ============ 龙虎榜选股配置 ============
# 启用龙虎榜选股模式（true/false）
LHB_MODE=false

# 龙虎榜查询日期（格式：YYYYMMDD，留空则查询今日）
# 例如：20260128
# LHB_DATE=

# 龙虎榜最低评分阈值（0-100，默认60）
# 评分越高筛选越严格，建议：
# - 60分：正常筛选，获取较多候选股
# - 70分：中等筛选，获取中等质量股票
# - 80分：严格筛选，只获取高质量股票
# - 85分以上：极严格筛选，只获取顶级股票
LHB_MIN_SCORE=60

# ============ 搜索服务配置 ============
# SerpAPI密钥（Google搜索）
SERPAPI_KEY=your_serpapi_key_here

# Tavily API密钥（备用搜索）
# TAVILY_API_KEY=your_tavily_api_key_here

# ============ 其他配置 ============
# 并发线程数（默认3）
# MAX_WORKERS=3

# 日志级别（debug/info/warn/error）
# RUST_LOG=info
